# InfraGenie backend environment — copy to backend/.env and fill in.

# --- MongoDB ---
MONGO_URL="mongodb://localhost:27017"
DB_NAME="infragenie"

# --- Auth ---
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
CORS_ORIGINS="http://localhost:3000"

# --- Guest admin user seeded on startup ---
ADMIN_EMAIL="guest@infragenie.io"
ADMIN_PASSWORD="Guest@321"

# --- Emergent Universal LLM key (fallback provider) ---
EMERGENT_LLM_KEY="sk-emergent-XXXXXXXX"

# --- Login brute-force lockout (optional overrides) ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MIN=15

# ============================================================
# Auto-seeded credentials for the demo/guest user.
# Leave BLANK if you don't want to auto-seed; users can enter
# these via the Settings page after signup instead.
# ============================================================

# Azure Service Principal (must have Reader+Contributor on the subscription)
GUEST_AZURE_TENANT_ID=""
GUEST_AZURE_SUBSCRIPTION_ID=""
GUEST_AZURE_CLIENT_ID=""
GUEST_AZURE_CLIENT_SECRET=""

# Azure OpenAI — used by Smart Assist + Provisioning agent
GUEST_AZURE_OPENAI_ENDPOINT="https://<your-account>.openai.azure.com/openai/v1"
GUEST_AZURE_OPENAI_API_KEY=""
GUEST_AZURE_OPENAI_DEPLOYMENT="gpt-4o"

# Terraform state storage (Azure Storage Account)
GUEST_TF_STORAGE_ACCOUNT=""
GUEST_TF_STORAGE_RG=""
GUEST_TF_STORAGE_CONTAINER="tfstate"
GUEST_TF_STORAGE_ACCESS_KEY=""
